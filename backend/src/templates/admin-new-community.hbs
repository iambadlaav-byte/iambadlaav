<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>New Community Sign-up</title>
  <style>
    body { font-family: 'DM Sans', Arial, sans-serif; background: #FFF0EA; color: #373735; margin: 0; padding: 0; }
    .wrapper { max-width: 600px; margin: 32px auto; background: #fff; border-radius: 6px; overflow: hidden; }
    .header { background: #C27D38; padding: 24px 32px; }
    .header h1 { color: #fff; font-size: 18px; margin: 0; font-weight: 600; }
    .header p { color: rgba(255,255,255,0.85); font-size: 13px; margin: 6px 0 0; }
    .body { padding: 28px 32px; }
    dl { margin: 0; }
    dt { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: #7a756f; margin-top: 16px; margin-bottom: 4px; }
    dd { font-size: 15px; color: #373735; margin: 0; }
    .footer { background: #f0ebe3; padding: 16px 32px; font-size: 12px; color: #7a756f; border-top: 1px solid #e0d9cf; }
    .id-badge { display: inline-block; background: #f0ebe3; border: 1px solid #C27D38; color: #C27D38; font-size: 11px; padding: 2px 8px; border-radius: 3px; font-family: monospace; margin-top: 4px; }
    .badge { display: inline-block; background: #C27D38; color: #fff; font-size: 11px; padding: 3px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.08em; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>New Community Sign-up</h1>
      <p>{{initiativeName}} · iambadlaav.com/community</p>
    </div>
    <div class="body">
      <dl>
        <dt>Initiative</dt>
        <dd><span class="badge">{{initiativeName}}</span></dd>

        <dt>Name</dt>
        <dd>{{name}}</dd>

        <dt>WhatsApp</dt>
        <dd>{{whatsapp}}</dd>

        <dt>City</dt>
        <dd>{{city}}</dd>

        {{#if email}}
        <dt>Email</dt>
        <dd><a href="mailto:{{email}}" style="color:#3d7a8a;">{{email}}</a></dd>
        {{/if}}

        {{#if occupation}}
        <dt>Occupation</dt>
        <dd>{{occupation}}</dd>
        {{/if}}

        <dt>Member ID</dt>
        <dd><span class="id-badge">{{memberId}}</span></dd>
      </dl>
    </div>
    <div class="footer">
      Add {{name}} to the {{initiativeName}} WhatsApp group.<br />
      Manage members under Admin → Community.
    </div>
  </div>
</body>
</html>
