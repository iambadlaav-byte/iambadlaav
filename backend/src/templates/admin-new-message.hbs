<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>New Contact Message</title>
  <style>
    body { font-family: 'DM Sans', Arial, sans-serif; background: #FFF0EA; color: #373735; margin: 0; padding: 0; }
    .wrapper { max-width: 600px; margin: 32px auto; background: #fff; border-radius: 6px; overflow: hidden; }
    .header { background: #015243; padding: 24px 32px; }
    .header h1 { color: #FAD062; font-size: 18px; margin: 0; font-weight: 600; }
    .header p { color: #e8f4f8; font-size: 13px; margin: 6px 0 0; }
    .body { padding: 28px 32px; }
    dl { margin: 0; }
    dt { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: #7a756f; margin-top: 16px; margin-bottom: 4px; }
    dd { font-size: 15px; color: #373735; margin: 0; }
    .message-body { background: #f0ebe3; border-radius: 4px; padding: 14px 16px; font-size: 15px; line-height: 1.7; color: #373735; margin-top: 4px; white-space: pre-wrap; word-break: break-word; }
    .footer { background: #f0ebe3; padding: 16px 32px; font-size: 12px; color: #7a756f; border-top: 1px solid #e0d9cf; }
    .id-badge { display: inline-block; background: #f0ebe3; border: 1px solid #C27D38; color: #C27D38; font-size: 11px; padding: 2px 8px; border-radius: 3px; font-family: monospace; margin-top: 4px; }
    .type-badge { display: inline-block; background: #015243; color: #e8f4f8; font-size: 11px; padding: 3px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.08em; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>New Contact Message</h1>
      <p>Received via iambadlaav.com/contact</p>
    </div>
    <div class="body">
      <dl>
        <dt>Enquiry Type</dt>
        <dd><span class="type-badge">{{enquiryType}}</span></dd>

        <dt>Name</dt>
        <dd>{{name}}</dd>

        <dt>Email</dt>
        <dd><a href="mailto:{{email}}" style="color:#3d7a8a;">{{email}}</a></dd>

        {{#if phone}}
        <dt>Phone</dt>
        <dd>{{phone}}</dd>
        {{/if}}

        <dt>Message</dt>
        <dd class="message-body">{{message}}</dd>

        <dt>Message ID</dt>
        <dd><span class="id-badge">{{messageId}}</span></dd>
      </dl>
    </div>
    <div class="footer">
      Reply directly to this email to reach {{name}} at {{email}}.<br />
      Manage under Admin → Messages.
    </div>
  </div>
</body>
</html>
